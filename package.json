{
  "name": "az-photo-command-center",
  "productName": "AZ Photo Command Center",
  "version": "1.0.6",
  "description": "AZ Photographer LLC Command Center",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "release-ota": "bash scripts/release-ota.sh"
  },
  "author": "AZ Photo LLC",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.3.0",
    "@electron-forge/maker-dmg": "^7.3.0",
    "@electron-forge/maker-zip": "^7.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.0.0",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "imap-simple": "^5.1.0",
    "lucide-react": "^0.354.0",
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.1"
  }
}
